{
  "name": "research-assistant-desktop",
  "version": "0.0.1",
  "description": "Electron shell for the Research Assistant — bundles the FastAPI backend + React frontend into a single installable desktop app.",
  "main": "build/main.js",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:icons": "../api/.venv/bin/python scripts/make_placeholder_icons.py",
    "build:backend": "../api/.venv/bin/python scripts/build_backend.py",
    "build:frontend": "npm --prefix ../web run build",
    "start": "npm run build && electron .",
    "dist": "npm run build && npm run build:icons && electron-builder",
    "dist:mac": "npm run build && npm run build:icons && electron-builder --mac",
    "dist:win": "npm run build && npm run build:icons && electron-builder --win"
  },
  "devDependencies": {
    "@types/node": "^24.12.3",
    "electron": "^34.5.8",
    "electron-builder": "^26.0.20",
    "get-port": "^7.1.0",
    "typescript": "~6.0.2"
  },
  "build": {
    "appId": "com.research-assistant.desktop",
    "productName": "Research Assistant",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "build/**/*",
      "!build/icons/*.png"
    ],
    "extraResources": [
      {
        "from": "dist/backend/research_api",
        "to": "backend",
        "filter": ["**/*"]
      },
      {
        "from": "../web/dist",
        "to": "web",
        "filter": ["**/*"]
      }
    ],
    "mac": {
      "target": ["dmg"],
      "icon": "build/icons/icon.icns",
      "category": "public.app-category.productivity",
      "identity": null,
      "hardenedRuntime": false
    },
    "dmg": {
      "title": "Research Assistant ${version}"
    },
    "win": {
      "target": ["nsis"],
      "icon": "build/icons/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
